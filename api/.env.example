# Copy to ".env" (same folder). Loaded automatically by app/config.py.

# Where the SQLite database file lives (relative to the api/ folder is fine).
DATABASE_URL=sqlite:///./tasks.db

# Printing:
#   console -> render the receipt text to the server log (no hardware needed; great for dev)
#   printer -> send to the real RP850 via python-escpos (needs the Windows driver installed)
PRINT_MODE=console

# The Windows printer name for the RP850 (same value you pass to rp850-printer's --printer).
# Find it with:  py ../rp850-printer/print_tasks.py --list
PRINTER_NAME=POS-80

# Characters per line on the RP850 (measured at 24 for Sierra's default font).
PRINT_WIDTH=24

# Comma-separated list of origins allowed to call the API (desktop/mobile dev servers).
# "*" is convenient for local dev; tighten for anything exposed beyond your LAN.
CORS_ORIGINS=*
